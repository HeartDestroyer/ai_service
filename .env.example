# Основные настройки приложения
CONTACT_NAME = "Имя Разработчика"
CONTACT_TG = "https://t.me/your_tg"
CONTACT_EMAIL = "dev@example.com"
DEBUG = true
ENVIRONMENT = "DEVELOPMENT" # "DEVELOPMENT" или "PRODUCTION"

# Настройки домена и мониторинга
DOMAIN = localhost
ACME_EMAIL = ...
MONITORING_ALLOWED_CIDRS = ...
TRAEFIK_HASH_PASSWORD = ...
TELEGRAM_ADMIN_CHAT_ID = ...
TELEGRAM_BOT_TOKEN = ...
GRAFANA_PASSWORD = ...

# Настройки безопасности
SECRET_KEY = "replace_with_64_characters_long_super_secret_key_for_jwt_and_encryption_1234567890"
API_KEY = '{"key_1":"replace_with_64_characters","key_2":"replace_with_64_characters_another"}'
DOCS_USERNAME = "admin"
DOCS_PASSWORD = "super_secret_docs_password"

# Настройки CORS
CORS_ALLOW_ORIGINS = "https://your-domain.com,https://crm.your-domain.com"

# Настройки базы данных
DB_HOST = "database"
DB_PORT = 5432
POSTGRES_USER = "postgres"
POSTGRES_PASSWORD = "replace_with_secure_postgres_password"
POSTGRES_DB = "postgres"
SQLALCHEMY_ECHO = true
MAX_CONNECT_DB = 200

# Настройки Redis
REDIS_HOST = "redis"
REDIS_PORT = 6379
REDIS_DB = 0
REDIS_PASSWORD = "replace_with_secure_redis_password"

# Настройки Dramatiq
DRAMATIQ_REDIS_HOST = "redis_dramatiq"
DRAMATIQ_REDIS_PORT = 6379
DRAMATIQ_REDIS_DB = 0
DRAMATIQ_REDIS_PASSWORD = "replace_with_secure_dramatiq_redis_password"
DRAMATIQ_PROCESSES = 2
DRAMATIQ_THREADS = 4
DRAMATIQ_METRICS_PORT = 9191
DRAMATIQ_REPORTS_TTL_DAYS = 5

# Cron-планировщик задач (SchedulerSettings, префикс SCHEDULE__)
SCHEDULE__DLQ_RETRY__HOUR = "*"
SCHEDULE__DLQ_RETRY__MINUTE = "*/15"

# Настройки интеграций
TOKEN_PROFILEHUB = "replace_with_profilehub_token"
URL_PROFILEHUB = "https://your-profilehub-domain.com"